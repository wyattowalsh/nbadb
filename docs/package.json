{
  "name": "nbadb-docs",
  "private": true,
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": ">=26 <27",
    "pnpm": ">=11 <12"
  },
  "prettier": {
    "semi": true,
    "singleQuote": false,
    "tabWidth": 2,
    "trailingComma": "all",
    "printWidth": 80
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "postinstall": "fumadocs-mdx",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@duckdb/duckdb-wasm": "1.33.1-dev57.0",
    "@observablehq/plot": "^0.6.17",
    "@orama/orama": "3.1.18",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.15",
    "@tanstack/react-table": "^8.21.3",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fumadocs-core": "16.10.6",
    "fumadocs-mdx": "15.0.13",
    "fumadocs-openapi": "11.0.6",
    "fumadocs-typescript": "5.2.7",
    "fumadocs-ui": "16.10.6",
    "lucide-react": "^1.22.0",
    "mermaid": "^11.16.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.9.0",
    "shadcn": "^4.12.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@fumadocs/cli": "1.3.10",
    "@next/eslint-plugin-next": "^16.2.9",
    "@tailwindcss/postcss": "4.3.1",
    "@types/node": "26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "prettier": "^3.9.3",
    "tailwindcss": "4.3.1",
    "typescript": "6.0.3",
    "vitest": "^4.1.9"
  }
}
