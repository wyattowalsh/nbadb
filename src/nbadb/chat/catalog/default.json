      "aliases": ["pace", "fastest pace", "slowest pace", "team pace"],
      "metrics": ["avg_pace", "avg_ortg", "avg_drtg"],
      "route": "team_pace",
      "patterns": ["team\\s+pace", "fastest\\s+pace", "slowest\\s+pace", "pace\\s+leaders?"]
    },
    {
      "name": "shot chart",
      "description": "Player shot locations and zones from fact_shot_chart.",
