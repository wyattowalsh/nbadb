      "aliases": ["shot chart", "shot locations", "shooting zones"],
      "metrics": ["shot_made_flag", "shot_zone_basic"],
      "route": "shot_chart",
      "patterns": ["shot\\s+chart", "shot\\s+locations?", "shooting\\s+zones?"]
    },
    {
